          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "refresh": 2,
        "definition": "label_values(finvibe_ws_active_connections, job)",
        "query": {
          "query": "label_values(finvibe_ws_active_connections, job)",
          "refId": "jobVar"
        },
        "multi": false,
        "includeAll": false,
        "current": {
          "selected": true,
          "text": "finvibe-websocket-listener",
          "value": "finvibe-websocket-listener"
        }
      },
      {
        "name": "instance",
        "type": "query",
        "label": "인스턴스",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "refresh": 2,
        "definition": "label_values(finvibe_ws_active_connections{job=~\"$job\"}, instance)",
        "query": {
          "query": "label_values(finvibe_ws_active_connections{job=~\"$job\"}, instance)",
          "refId": "instanceVar"
        },
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": ".*"
        }
      }
    ]
