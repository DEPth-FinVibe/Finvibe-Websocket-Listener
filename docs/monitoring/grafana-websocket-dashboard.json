          "expr": "100 * sum(rate(finvibe_ws_event_delivery_failures_total{job=~\"$job\",instance=~\"$instance\"}[5m])) / clamp_min(sum(rate(finvibe_ws_event_deliveries_total{job=~\"$job\",instance=~\"$instance\"}[5m])), 1)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none"
      }
    },
